# Copy to deploy/prod.env on the production server and fill values.
# Do NOT commit secrets.

# Required: model served by Ollama
OLLAMA_MODEL=latin-en-trained

# Required: Ollama endpoint reachable from API container
# Example if Ollama is on same host:
# OLLAMA_BASE_URL=http://host.docker.internal:11434
# Example if Ollama is on private network:
# OLLAMA_BASE_URL=http://10.10.0.25:11434
OLLAMA_BASE_URL=http://host.docker.internal:11434

# Optional metadata
APP_ENV=production
APP_NAME=latin-rag-translator-api
